      - fonts-powerline
      - fzf
      - git
      - git-delta
      - git-filter-repo
      - gnome-tweaks
      - google-chrome-stable
      - google-cloud-cli
      - jq
      - lxc
      - ncdu
      - neovim
      - pass
      - ripgrep
      - stow
      - tailscale
      - tealdeer
      - tmux
